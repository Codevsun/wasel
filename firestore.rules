rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isSignedIn()    { return request.auth != null; }
    // Prefer custom claim; fall back to Firestore user doc (Spark plan / before claims sync).
    function role() {
      return request.auth.token.role != null
        ? request.auth.token.role
        : (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
            : null);
    }
    function isTrainer()     { return isSignedIn() && role() == "trainer"; }
    function isIntern()      { return isSignedIn() && role() == "intern"; }
    function isManagement()  { return isSignedIn() && role() == "management"; }
    function isOwner(uid)    { return isSignedIn() && request.auth.uid == uid; }

    // Check if intern belongs to a cohort (reads cohort doc)
    function isCohortMember(cohortId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/cohorts/$(cohortId)).data.member_uids;
    }

    // ── users ─────────────────────────────────────────────────────
    // write: trainer only | read: own doc OR trainer
    match /users/{uid} {
      allow read:  if isOwner(uid) || isTrainer();
      allow write: if isTrainer();
    }

    // ── cohorts ───────────────────────────────────────────────────
    // write: trainer only | read: trainer + management + members
    match /cohorts/{cohortId} {
      allow read:  if isTrainer() || isManagement() ||
                      (isIntern() && request.auth.uid in resource.data.member_uids);
      allow write: if isTrainer();
    }

    // ── groups ────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read:  if isTrainer() || isManagement() ||
                      (isIntern() && request.auth.uid in resource.data.member_uids);
      allow write: if isTrainer();
    }

    // ── plans / tracks / modules / milestones / tasks ─────────────
    // write: trainer only | read: trainer + assigned interns
    match /plans/{planId} {
      allow read:  if isTrainer() || isIntern();
      allow write: if isTrainer();
    }
    match /tracks/{trackId} {
      allow read:  if isTrainer() || isIntern();
      allow write: if isTrainer();
    }
    match /modules/{moduleId} {
      allow read:  if isTrainer() || isIntern();
      allow write: if isTrainer();
    }
    match /milestones/{milestoneId} {
      allow read:  if isTrainer() || isIntern();
      allow write: if isTrainer();
    }
    match /tasks/{taskId} {
      allow read:  if isTrainer() || isIntern();
      allow write: if isTrainer();
    }

    // ── outcomes ──────────────────────────────────────────────────
    // write: own uid only | read: own uid OR trainer
    match /outcomes/{outcomeId} {
      allow read:  if isTrainer() ||
                      (isIntern() && resource.data.user_id == request.auth.uid);
      allow create: if isTrainer() ||
                      (isIntern() && request.resource.data.user_id == request.auth.uid);
      allow update: if isTrainer() ||
                      (isIntern() && resource.data.user_id == request.auth.uid);
    }

    // ── submissions ───────────────────────────────────────────────
    // write: own uid only | read: own uid OR trainer
    match /submissions/{submissionId} {
      allow read:  if isTrainer() ||
                      (isIntern() && resource.data.user_id == request.auth.uid);
      allow create: if isIntern() && request.resource.data.user_id == request.auth.uid;
      allow update: if isTrainer() ||
                      (isIntern() && resource.data.user_id == request.auth.uid);
    }

    // ── progress ──────────────────────────────────────────────────
    // write: own uid only | read: own uid OR trainer OR management
    match /progress/{uid} {
      allow read:  if isOwner(uid) || isTrainer() || isManagement();
      // Interns update own progress; trainers update when approving submissions
      allow write: if isOwner(uid) || isTrainer();
    }

    // ── quizzes ───────────────────────────────────────────────────
    // write: trainer only | read: trainer + interns
    match /quizzes/{taskId} {
      allow read:  if isTrainer() || isIntern();
      allow write: if isTrainer();
    }

    // ── quiz_results ──────────────────────────────────────────────
    // write: own uid only | read: own uid OR trainer
    match /quiz_results/{resultId} {
      allow read:  if isTrainer() ||
                      (isIntern() && resource.data.user_id == request.auth.uid);
      allow create: if isIntern() && request.resource.data.user_id == request.auth.uid;
      allow update: if isIntern() && resource.data.user_id == request.auth.uid;
    }

    // ── discussions ───────────────────────────────────────────────
    // write + read: cohort members + trainer
    match /discussions/{discussionId} {
      allow read:  if isTrainer() || isIntern();
      allow create: if isTrainer() || isIntern();
      allow update: if isTrainer() ||
                      (isIntern() && resource.data.author_uid == request.auth.uid);
    }

    // ── announcements ─────────────────────────────────────────────
    // write: trainer only | read: all signed-in users
    match /announcements/{announcementId} {
      allow read:  if isSignedIn();
      allow write: if isTrainer();
    }

    // ── task_templates ────────────────────────────────────────────
    // write: trainer only | read: trainer only
    match /task_templates/{templateId} {
      allow read:  if isTrainer();
      allow write: if isTrainer();
    }

    // ── config ────────────────────────────────────────────────────
    // write: trainer only | read: all signed-in (interns need track/label options)
    match /config/{docId} {
      allow read:  if isSignedIn();
      allow write: if isTrainer();
    }
  }
}
